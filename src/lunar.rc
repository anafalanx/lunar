#include <winver.h>
#include <windows.h>

// -------------------------------------------------------------------
// Version macros.
//
// scripts/build.py reads the top-level VERSION file and passes these
// via windres -D, so VERSION is the single source of truth.  The
// fallbacks below only exist so a bare `windres lunar.rc` still
// compiles; keep them in sync with VERSION.
// -------------------------------------------------------------------

#ifndef LUNAR_VERSION_STR
#define LUNAR_VERSION_STR "0.50"
#endif
#ifndef LUNAR_VERSION_MAJOR
#define LUNAR_VERSION_MAJOR 0
#endif
#ifndef LUNAR_VERSION_MINOR
#define LUNAR_VERSION_MINOR 50
#endif
#ifndef LUNAR_VERSION_PATCH
#define LUNAR_VERSION_PATCH 0
#endif

1 ICON "..\\assets\\icon.ico"

// Embed the application manifest (v6 comctl32 + PerMonitorV2 DPI).
// CREATEPROCESS_MANIFEST_RESOURCE_ID = 1, RT_MANIFEST = 24.
1 24 "lunar.manifest"

// -------------------------------------------------------------------
// Settings dialog (IDD_SETTINGS = 100)
//
// Themed modal with three sections (Chimes, General, Time zone) and a
// live "current time in selected zone" preview.  Segoe UI 9 matches
// the Vista+ shell convention; DS_SHELLFONT lets the OS substitute
// the right UI font on non-English systems.
//
// Units are DLU (1 DLU ~= 1/4 of the base character width of the
// dialog font).  Dialog is 280 x 215 DLU ~= 462 x 355 px @ 96 dpi.
// -------------------------------------------------------------------

100 DIALOGEX 0, 0, 280, 237
STYLE DS_SETFONT | DS_SHELLFONT | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Lunar Settings"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    GROUPBOX        "Chimes",                         -1,      7,   4, 266,  46
    AUTOCHECKBOX    "Play a &chime on armed 5-minute marks",
                                                      1001,   15,  17, 180,  10
    AUTOCHECKBOX    "&Un-minimize the window on armed marks",
                                                      1002,   15,  31, 180,  10
    PUSHBUTTON      "&Test chime",                    1007,  199,  27,  66,  14

    GROUPBOX        "General",                        -1,      7,  56, 266,  68
    AUTOCHECKBOX    "Confirm before &closing the window",
                                                      1003,   15,  68, 248,  10
    AUTOCHECKBOX    "Use 24-&hour clock in title bar",
                                                      1009,   15,  82, 248,  10
    AUTOCHECKBOX    "&Minimize to the notification area (tray)",
                                                      1010,   15,  96, 248,  10
    AUTOCHECKBOX    "&Start Lunar when you sign in",
                                                      1011,   15, 110, 248,  10

    GROUPBOX        "Display time zone",              -1,      7, 130, 266,  68
    LTEXT           "&Filter:",                       -1,     15, 146,  28,  10
    EDITTEXT                                          1005,   47, 144, 218,  12, ES_AUTOHSCROLL
    LTEXT           "&Zone:",                         -1,     15, 164,  28,  10
    COMBOBOX                                          1004,   47, 162, 218, 140,
                    CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Current time:",                  -1,     15, 182,  52,  10
    LTEXT           "",                               1006,   67, 182, 198,  10

    PUSHBUTTON      "&Defaults",                      1008,    7, 215,  60,  14
    DEFPUSHBUTTON   "OK",                             IDOK,  159, 215,  52,  14
    PUSHBUTTON      "Cancel",                         IDCANCEL,217, 215,  52,  14
END

// -------------------------------------------------------------------
// About dialog (IDD_ABOUT = 101)
//
// Minimal modal: app icon on the left, a small stack of labels on the
// right, and a single OK button.  No runtime diagnostics -- the Log
// viewer is where the sync / clockwork details live.
// -------------------------------------------------------------------

101 DIALOGEX 0, 0, 200, 138
STYLE DS_SETFONT | DS_SHELLFONT | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About Lunar"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    ICON            "",                               2001,    52,  11,  28,  28
    LTEXT           "Lunar",                          2002,    90,  12, 100,  18
    LTEXT           "Version " LUNAR_VERSION_STR,     2003,    90,  30, 100,  10
    LTEXT           "A minimalist analog clock.",     2004,    12,  52, 176,  10, SS_CENTER
    LTEXT           "Native Win32 with Direct2D rendering.",
                                                      2005,    12,  64, 176,  10, SS_CENTER
    LTEXT           "Runs independently of the system clock.",
                                                      2007,    12,  76, 176,  10, SS_CENTER
    LTEXT           "",                               2006,    12,  94, 176,  10, SS_CENTER
    LTEXT           "",                               2008,    12, 106, 176,  10, SS_CENTER
    DEFPUSHBUTTON   "OK",                             IDOK,   146, 120,  46,  14
END

1 VERSIONINFO
 FILEVERSION LUNAR_VERSION_MAJOR,LUNAR_VERSION_MINOR,LUNAR_VERSION_PATCH,0
 PRODUCTVERSION LUNAR_VERSION_MAJOR,LUNAR_VERSION_MINOR,LUNAR_VERSION_PATCH,0
 FILEOS VOS__WINDOWS32
 FILETYPE VFT_APP
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", "Lunar"
            VALUE "FileDescription", "Lunar - analog clock"
            VALUE "FileVersion", LUNAR_VERSION_STR
            VALUE "InternalName", "Lunar"
            VALUE "OriginalFilename", "Lunar.exe"
            VALUE "ProductName", "Lunar"
            VALUE "ProductVersion", LUNAR_VERSION_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
